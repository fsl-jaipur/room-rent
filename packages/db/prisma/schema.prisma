generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Users {
  userId          String   @id @default(uuid()) @map("UserId") @db.UniqueIdentifier
  userName        String   @map("UserName") @db.NVarChar(255)
  phone           String   @map("Phone") @db.VarChar(20)
  userEmail       String   @map("UserEmail") @db.NVarChar(255)
  aadhaarNumber   String   @map("AadhaarNumber") @db.VarChar(12)
  localAddress    String   @map("LocalAddress") @db.NVarChar(500)
  hometownAddress String   @map("HometownAddress") @db.NVarChar(500)
  profilePhotoUrl String   @map("ProfilePhotoUrl") @db.NVarChar(1000)
  isActive        Boolean? @map("IsActive")
  createdAt       DateTime? @map("CreatedAt")
  createdBy       String?  @map("CreatedBy") @db.NVarChar(255)
  updatedAt       DateTime? @map("UpdatedAt")
  updatedBy       String?  @map("UpdatedBy") @db.NVarChar(255)

  @@map("Users")
}
